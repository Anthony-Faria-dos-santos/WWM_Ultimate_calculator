# ===========================================
# WWM Ultimate Calculator - Configuration
# ===========================================
# Copier ce fichier vers .env.local et remplir les valeurs
# Ne JAMAIS commiter .env.local
# ===========================================

# ========== DATABASE ==========
DATABASE_URL="postgresql://user:password@localhost:5432/wwm_calculator"

# ========== NEXTAUTH ==========
# Générer avec: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ========== OAUTH PROVIDERS (optionnel) ==========
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ========== STRIPE ==========
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Price IDs (créer dans Stripe Dashboard)
STRIPE_PRICE_PREMIUM="price_..."
STRIPE_PRICE_PREMIUM_PLUS="price_..."

# ========== AI (Claude API) ==========
ANTHROPIC_API_KEY="sk-ant-..."

# ========== EMAIL (Resend) ==========
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@votredomaine.com"

# ========== RATE LIMITING (Upstash Redis) ==========
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ========== MONITORING (optionnel) ==========
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ========== ANALYTICS (optionnel) ==========
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""
