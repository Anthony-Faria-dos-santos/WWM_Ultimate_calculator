# ===========================================
# NPM Security Configuration
# ===========================================

# Require exact versions to prevent supply chain attacks
save-exact=true

# Audit on install
audit=true

# Use package-lock.json
package-lock=true

# Engine strict mode
engine-strict=true

# Refuse to install packages with vulnerabilities
# (uncomment in production)
# audit-level=high

# Registry (use official npm registry)
registry=https://registry.npmjs.org/
